# Plantilla de variables de entorno para nube-eficiente.
# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
#
# El archivo .env NUNCA se commitea (está en .gitignore) porque contiene secretos.

# --- Base de datos ---
# Cadena de conexión PostgreSQL. Los valores por defecto coinciden con docker-compose.yml.
DATABASE_URL=postgresql://cloudwise:cloudwise_dev@localhost:5432/cloudwise

# --- Credenciales de Azure (service principal) ---
# Se obtienen al registrar una aplicación en Azure Active Directory (Entra ID).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
